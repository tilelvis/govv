{
  "name": "ke-govvault-web",
  "version": "1.0.0",
  "private": true,
  "description": "KE GovVault — Kenya Government Document Intelligence Dashboard",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "prisma generate && prisma db push --skip-generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.11.1",
    "lucide-react": "^0.525.0",
    "next": "^16.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "z-ai-web-dev-sdk": "^0.0.18"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "prisma": "^6.11.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
